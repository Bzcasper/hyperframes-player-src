# Required: token for uploading rendered MP4s to Vercel Blob.
# Auto-provisioned when you attach a Blob store to the project.
# Locally: run `vercel env pull` after linking the project.
BLOB_READ_WRITE_TOKEN=

# Sandbox auth is automatic on Vercel (via VERCEL_OIDC_TOKEN).
# For local dev against a real sandbox, pull the OIDC token with:
#   vercel env pull
